# OpenAI/LiteLLM Configuration
OPENAI_API_KEY=your_api_key_here
LITELLM_BASE_URL=https://api.ai.it.ufl.edu

# FastAPI Configuration
API_HOST=0.0.0.0
API_PORT=8000

# JWT Configuration (REQUIRED: Change in production!)
JWT_SECRET=your-secret-key-change-this-in-production-with-a-strong-random-key

# CORS Configuration (comma-separated allowed origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
FRONTEND_URL=http://localhost:3000

# Logging Configuration
LOG_LEVEL=INFO
